{
    "scripts": {
      "dokku": {
        "predeploy": "python manage.py migrate --noinput"
      }
    },
    "cron": [
      {
        "command": "python manage.py post_random_library",
        "schedule": "0 10 * * *"
      },
      {
        "command": "python manage.py refresh_instagram_token",
        "schedule": "0 9 */30 * *"
      }
    ],
    "healthchecks": {
      "web": [
        {
          "type": "startup",
          "name": "web check",
          "path": "/health/",
          "attempts": 3,
          "timeout": 5,
          "wait": 5
        }
      ]
    }
}
